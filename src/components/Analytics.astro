---
// GA4 Analytics component
// Replace G-XXXXXXXXXX with your actual GA4 Measurement ID
const GA_ID = import.meta.env.PUBLIC_GA4_ID || 'G-G8E4RJ95YB';
---

<!-- Google Analytics 4 -->
<script is:inline define:vars={{ GA_ID }}>
  // Load gtag.js
  const script = document.createElement('script');
  script.async = true;
  script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
  document.head.appendChild(script);

  window.dataLayer = window.dataLayer || [];
  function gtag() { dataLayer.push(arguments); }
  gtag('js', new Date());
  gtag('config', GA_ID, { send_page_view: true });

  // Track page views on Astro client-side navigation (View Transitions)
  document.addEventListener('astro:page-load', () => {
    gtag('event', 'page_view', {
      page_path: window.location.pathname,
      page_title: document.title,
    });
  });

  // Custom event helpers (available globally)
  window.trackEvent = function(eventName, params) {
    gtag('event', eventName, params);
  };
</script>
