---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/solutions", label: "Solutions" },
  { href: "/case-study", label: "Case Study" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-slate-900 border-b border-slate-800">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="text-xl font-bold text-white tracking-tight">
        zenprocess<span class="text-blue-500">.ai</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-6">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors",
              isActive(link.href)
                ? "text-blue-400"
                : "text-slate-300 hover:text-white",
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="tel:+18329742818"
          class="text-sm font-medium text-slate-300 hover:text-white transition-colors"
        >
          (832) 974-2818
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden text-slate-300 hover:text-white"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-3 pt-2">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium py-1 transition-colors",
              isActive(link.href)
                ? "text-blue-400"
                : "text-slate-300 hover:text-white",
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="tel:+18329742818"
          class="text-sm font-medium text-slate-300 hover:text-white py-1 transition-colors"
        >
          (832) 974-2818
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    hamburgerIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
    btn.setAttribute("aria-expanded", String(isOpen));
  });
</script>
