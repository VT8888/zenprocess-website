---
import ThemeToggle from './ThemeToggle.astro';
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/solutions", label: "Solutions" },
  { href: "/case-study", label: "Case Study" },
  { href: "/about", label: "About" },
  { href: "/resources", label: "Resources" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-[var(--header-bg)] backdrop-blur-xl border-b border-[var(--glass-border)]">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 text-2xl font-bold text-[var(--text-primary)] tracking-tight">
        <img src="/logo.png" alt="zenprocess.ai" class="h-10 w-10" />
        zenprocess.ai
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-5">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors",
              isActive(link.href)
                ? "text-[#22C55E]"
                : "text-[var(--text-primary-80)] hover:text-[var(--text-primary)]",
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="tel:+18329742818"
          class="text-sm font-medium text-[var(--text-primary-80)] hover:text-[var(--text-primary)] transition-colors"
        >
          (832) 974-2818
        </a>
        <ThemeToggle />
        <a
          href="/book"
          class="ml-2 bg-[#16A34A] hover:bg-[#15803D] text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors shadow-[0_4px_20px_rgba(22,163,74,0.3)]"
        >
          Book a Call
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden text-[var(--text-primary-80)] hover:text-[var(--text-primary)]"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 bg-[var(--bg-primary)] rounded-b-xl -mx-4 px-4">
      <div class="flex flex-col gap-3 pt-2">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium py-1 transition-colors",
              isActive(link.href)
                ? "text-[#22C55E]"
                : "text-[var(--text-primary-80)] hover:text-[var(--text-primary)]",
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="tel:+18329742818"
          class="text-sm font-medium text-[var(--text-primary-80)] hover:text-[var(--text-primary)] py-1 transition-colors"
        >
          (832) 974-2818
        </a>
        <a
          href="/book"
          class="mt-2 bg-[#16A34A] hover:bg-[#15803D] text-white text-sm font-semibold px-5 py-3 rounded-lg text-center transition-colors shadow-[0_4px_20px_rgba(22,163,74,0.3)]"
        >
          Book a Call
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    hamburgerIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
    btn.setAttribute("aria-expanded", String(isOpen));
  });
</script>
