---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/solutions", label: "Solutions" },
  { href: "/case-study", label: "Case Study" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 border-t border-slate-800">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand + Description -->
      <div>
        <a href="/" class="text-lg font-bold text-white tracking-tight">
          zenprocess<span class="text-blue-500">.ai</span>
        </a>
        <p class="mt-3 text-sm text-slate-400 leading-relaxed">
          AI systems architecture and digital transformation for mid-market companies.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Navigation</h3>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Contact</h3>
        <ul class="space-y-2 text-sm text-slate-400">
          <li>
            <a href="mailto:info@zenprocess.ai" class="hover:text-white transition-colors">
              info@zenprocess.ai
            </a>
          </li>
          <li>
            <a href="tel:+18329742818" class="hover:text-white transition-colors">
              (832) 974-2818
            </a>
          </li>
          <li>Houston, TX</li>
          <li>
            <a
              href="https://linkedin.com/company/zenprocess"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition-colors"
            >
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 pt-6 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500">
        &copy; {currentYear} KMV Group LLC dba zenprocess.ai. All rights reserved.
      </p>
      <div class="flex gap-4">
        <a href="/privacy" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">
          Privacy Policy
        </a>
        <a href="/terms" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
