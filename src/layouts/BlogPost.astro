---
import Layout from "./Layout.astro";
import StructuredData from "../components/StructuredData.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  description: string;
  date: string;
  author: string;
  authorTitle: string;
  pillar: "data_problem" | "operational_intelligence" | "industry_insights" | "proof_and_results";
  seoKeywords?: string[];
  slug?: string;
  draft?: boolean;
}

const { title, description, date, author, authorTitle, pillar, seoKeywords, slug } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// Related posts: same pillar first, then other posts, excluding current. Max 3.
const allBlog = await getCollection("blog", ({ data }) => !data.draft);
const others = allBlog.filter((p) => p.id !== slug);
const samePillar = others.filter((p) => p.data.pillar === pillar);
const otherPillar = others.filter((p) => p.data.pillar !== pillar);
const related = [...samePillar, ...otherPillar].slice(0, 3);

const pillarConfig: Record<string, { label: string; bg: string; text: string }> = {
  data_problem: { label: "Data Problem", bg: "bg-red-500/20", text: "text-red-400" },
  operational_intelligence: { label: "Operational Intelligence", bg: "bg-green-500/20", text: "text-green-400" },
  industry_insights: { label: "Industry Insights", bg: "bg-blue-500/20", text: "text-blue-400" },
  proof_and_results: { label: "Proof & Results", bg: "bg-amber-500/20", text: "text-amber-400" },
};

const pillarInfo = pillarConfig[pillar];

function formatDate(dateStr: string): string {
  // Force UTC so frontmatter date "2026-04-22" renders as April 22
  // regardless of reader's timezone.
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<Layout title={title} description={description} ogType="article" canonicalURL={canonicalURL}>
  <StructuredData type="article" data={{
    headline: title,
    description,
    datePublished: date,
    dateModified: date,
    authorName: author,
    authorTitle,
    url: canonicalURL,
    keywords: seoKeywords,
  }} />
  <StructuredData type="breadcrumb" data={{
    items: [
      { name: "Home", url: "https://zenprocess.ai/" },
      { name: "Resources", url: "https://zenprocess.ai/resources" },
      { name: title, url: canonicalURL },
    ],
  }} />
  <article class="pt-20 pb-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">

      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm text-[var(--text-secondary)]">
        <a href="/" class="hover:text-[#22C55E] transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/resources" class="hover:text-[#22C55E] transition-colors">Resources</a>
        <span class="mx-2">/</span>
        <span class="text-[var(--text-primary-60)]">{title}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12">
        <!-- Main Content -->
        <div>
          <!-- Article Header -->
          <header class="mb-10">
            <div class="flex items-center gap-3 mb-4">
              <span class={`inline-block text-xs font-medium px-2.5 py-1 rounded-full ${pillarInfo.bg} ${pillarInfo.text}`}>
                {pillarInfo.label}
              </span>
              <time class="text-sm text-[var(--text-secondary)]" datetime={date}>
                {formatDate(date)}
              </time>
            </div>
            <h1 class="text-3xl sm:text-4xl font-bold text-[var(--text-primary)] leading-tight mb-4">
              {title}
            </h1>
            <p class="text-[var(--text-secondary)] text-sm">
              By <span class="text-[var(--text-primary)] font-medium">{author}</span> — {authorTitle}
            </p>
          </header>

          <!-- Article Body -->
          <div class="prose-blog max-w-3xl">
            <slot />
          </div>

          {related.length > 0 && (
            <section class="mt-16 pt-10 border-t border-[var(--glass-border)] max-w-3xl">
              <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">Related Articles</h2>
              <ul class="space-y-5">
                {related.map((post) => {
                  const rPillar = pillarConfig[post.data.pillar];
                  return (
                    <li>
                      <a href={`/resources/${post.id}`} class="group block">
                        <div class="flex items-center gap-2 mb-1.5">
                          <span class={`inline-block text-[10px] font-medium px-2 py-0.5 rounded-full ${rPillar.bg} ${rPillar.text}`}>
                            {rPillar.label}
                          </span>
                          <time class="text-xs text-[var(--text-secondary)]" datetime={post.data.date}>
                            {formatDate(post.data.date)}
                          </time>
                        </div>
                        <h3 class="text-base font-semibold text-[var(--text-primary)] group-hover:text-[#22C55E] transition-colors mb-1">
                          {post.data.title}
                        </h3>
                        <p class="text-sm text-[var(--text-secondary)] leading-relaxed line-clamp-2">
                          {post.data.description}
                        </p>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </section>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6 lg:pt-20">
          <!-- Author Box -->
          <div class="bg-[var(--glass-bg)] backdrop-blur-xl border border-[var(--glass-border)] rounded-xl p-5">
            <div class="flex items-center gap-3 mb-3">
              <img
                src="/vinh-photo.jpg"
                alt={author}
                class="w-12 h-12 rounded-full object-cover border border-[var(--hover-border)]"
                loading="lazy"
              />
              <div>
                <p class="text-sm font-semibold text-[var(--text-primary)]">{author}</p>
                <p class="text-xs text-[var(--text-secondary)]">{authorTitle}</p>
              </div>
            </div>
            <p class="text-xs text-[var(--text-secondary)] leading-relaxed mb-3">
              20+ years enterprise IT & CTO leadership. Helping building materials distributors unlock operational intelligence.
            </p>
            <a
              href="https://www.linkedin.com/in/vttruong/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-[#22C55E] hover:underline font-medium"
            >
              Connect on LinkedIn
            </a>
          </div>

          <!-- CTA Box -->
          <div class="bg-[var(--glass-bg)] backdrop-blur-xl border border-[var(--glass-border)] rounded-xl p-5">
            <p class="text-sm font-semibold text-white mb-2">Want to discuss your operation?</p>
            <p class="text-xs text-[var(--text-secondary)] mb-4">
              See how operational intelligence applies to your distribution business.
            </p>
            <a
              href="/book"
              class="block text-center text-sm font-medium px-4 py-2.5 rounded-lg bg-[#16A34A] text-white hover:bg-[#15803d] transition-colors"
            >
              Meet with Us
            </a>
          </div>

          <!-- Related Links -->
          <div class="bg-[var(--glass-bg)] backdrop-blur-xl border border-[var(--glass-border)] rounded-xl p-5">
            <p class="text-sm font-semibold text-white mb-3">Explore More</p>
            <ul class="space-y-2">
              <li>
                <a href="/case-study" class="text-xs text-[#22C55E] hover:underline font-medium">
                  Read the Case Study
                </a>
              </li>
              <li>
                <a href="/solutions" class="text-xs text-[#22C55E] hover:underline font-medium">
                  See Our Solutions
                </a>
              </li>
              <li>
                <a href="/resources" class="text-xs text-[#22C55E] hover:underline font-medium">
                  All Resources
                </a>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .prose-blog h2 {
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose-blog h3 {
    color: var(--text-primary);
    font-weight: 600;
    font-size: 1.25rem;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .prose-blog p {
    color: var(--text-primary-80);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }

  .prose-blog a {
    color: #22C55E;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }

  .prose-blog a:hover {
    color: #16A34A;
  }

  .prose-blog ul,
  .prose-blog ol {
    color: var(--text-primary-80);
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    line-height: 1.75;
  }

  .prose-blog ul {
    list-style-type: disc;
  }

  .prose-blog ol {
    list-style-type: decimal;
  }

  .prose-blog li {
    margin-bottom: 0.375rem;
  }

  .prose-blog blockquote {
    border-left: 3px solid #22C55E;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-primary-70);
    font-style: italic;
  }

  .prose-blog code {
    background: var(--code-bg);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: 'IBM Plex Mono', monospace;
    color: var(--text-primary);
  }

  .prose-blog pre {
    background: var(--pre-bg);
    border: 1px solid var(--pre-border);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose-blog pre code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .prose-blog strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .prose-blog em {
    color: var(--text-primary-70);
  }

  .prose-blog hr {
    border-color: var(--glass-border);
    margin: 2rem 0;
  }

  .prose-blog img {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
</style>
