---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const pillarConfig: Record<string, { label: string; bg: string; text: string }> = {
  data_problem: { label: "Data Problem", bg: "bg-red-500/20", text: "text-red-400" },
  operational_intelligence: { label: "Operational Intelligence", bg: "bg-green-500/20", text: "text-green-400" },
  industry_insights: { label: "Industry Insights", bg: "bg-blue-500/20", text: "text-blue-400" },
  proof_and_results: { label: "Proof & Results", bg: "bg-amber-500/20", text: "text-amber-400" },
};

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  title="Resources — Insights for Building Materials Distributors"
  description="Articles on operational intelligence, data pipelines, and real-time dashboards for building materials distributors."
>
  <!-- Hero -->
  <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Resources</h1>
      <p class="text-lg text-[#978aa1] max-w-2xl mx-auto">
        Insights on operational intelligence for building materials distributors.
      </p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="pb-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {posts.map((post) => {
            const pillar = pillarConfig[post.data.pillar];
            return (
              <a
                href={`/resources/${post.id}`}
                class="group block bg-white/5 backdrop-blur-xl border border-white/10 rounded-xl p-6 transition-all hover:bg-white/10 hover:border-white/20"
              >
                <div class="flex items-center gap-3 mb-3">
                  <span class={`inline-block text-xs font-medium px-2.5 py-1 rounded-full ${pillar.bg} ${pillar.text}`}>
                    {pillar.label}
                  </span>
                  <time class="text-xs text-[#978aa1]" datetime={post.data.date}>
                    {formatDate(post.data.date)}
                  </time>
                </div>
                <h2 class="text-lg font-semibold text-white group-hover:text-[#22C55E] transition-colors mb-2">
                  {post.data.title}
                </h2>
                <p class="text-sm text-[#978aa1] leading-relaxed">
                  {post.data.description}
                </p>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16 bg-white/5 backdrop-blur-xl border border-white/10 rounded-xl">
          <p class="text-[#978aa1] text-lg">
            Articles coming soon. Follow us on{" "}
            <a
              href="https://www.linkedin.com/in/vttruong/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#22C55E] hover:underline"
            >
              LinkedIn
            </a>{" "}
            for weekly insights.
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- Email Signup -->
  <section class="pb-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <div class="bg-white/5 backdrop-blur-xl border border-[#16A34A]/20 rounded-xl p-8 text-center">
        <h3 class="text-xl font-bold text-white mb-2">Get insights delivered</h3>
        <p class="text-[#978aa1] mb-6">Join building materials distribution leaders who get our latest articles and industry analysis.</p>
        <form action="https://links.zenprocess.ai/widget/form/YOUR_FORM_ID" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            type="email"
            name="email"
            placeholder="Enter your email"
            required
            class="flex-1 px-4 py-3 bg-white/10 border border-white/10 rounded-lg text-white placeholder-[#6b5e75] focus:outline-none focus:border-[#16A34A] transition-colors"
          />
          <button
            type="submit"
            class="bg-[#16A34A] hover:bg-[#15803D] text-white font-semibold px-6 py-3 rounded-lg transition-colors shadow-[0_4px_20px_rgba(22,163,74,0.3)] whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
        <p class="text-xs text-[#6b5e75] mt-4">No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>
</Layout>
