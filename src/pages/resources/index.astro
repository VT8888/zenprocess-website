---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const pillarConfig: Record<string, { label: string; bg: string; text: string }> = {
  data_problem: { label: "Data Problem", bg: "bg-red-500/20", text: "text-red-400" },
  operational_intelligence: { label: "Operational Intelligence", bg: "bg-green-500/20", text: "text-green-400" },
  industry_insights: { label: "Industry Insights", bg: "bg-blue-500/20", text: "text-blue-400" },
  proof_and_results: { label: "Proof & Results", bg: "bg-amber-500/20", text: "text-amber-400" },
};

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  title="Resources — Insights for Building Materials Distributors"
  description="Articles on operational intelligence, data pipelines, and real-time dashboards for building materials distributors."
>
  <!-- Hero -->
  <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-[var(--text-primary)] mb-4">Resources</h1>
      <p class="text-lg text-[var(--text-secondary)] max-w-2xl mx-auto">
        Insights on operational intelligence for building materials distributors.
      </p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="pb-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {posts.map((post) => {
            const pillar = pillarConfig[post.data.pillar];
            return (
              <a
                href={`/resources/${post.id}`}
                class="group block bg-[var(--glass-bg)] backdrop-blur-xl border border-[var(--glass-border)] rounded-xl p-6 transition-all hover:bg-[var(--hover-bg)] hover:border-[var(--hover-border)]"
              >
                <div class="flex items-center gap-3 mb-3">
                  <span class={`inline-block text-xs font-medium px-2.5 py-1 rounded-full ${pillar.bg} ${pillar.text}`}>
                    {pillar.label}
                  </span>
                  <time class="text-xs text-[var(--text-secondary)]" datetime={post.data.date}>
                    {formatDate(post.data.date)}
                  </time>
                </div>
                <h2 class="text-lg font-semibold text-[var(--text-primary)] group-hover:text-[#22C55E] transition-colors mb-2">
                  {post.data.title}
                </h2>
                <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
                  {post.data.description}
                </p>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16 bg-[var(--glass-bg)] backdrop-blur-xl border border-[var(--glass-border)] rounded-xl">
          <p class="text-[var(--text-secondary)] text-lg">
            Articles coming soon. Follow us on{" "}
            <a
              href="https://www.linkedin.com/in/vttruong/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#22C55E] hover:underline"
            >
              LinkedIn
            </a>{" "}
            for weekly insights.
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- Email Signup -->
  <section class="pb-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <div class="bg-[var(--glass-bg)] backdrop-blur-xl border border-[#16A34A]/20 rounded-xl p-8 text-center">
        <h3 class="text-xl font-bold text-[var(--text-primary)] mb-2">Get insights delivered</h3>
        <p class="text-[var(--text-secondary)] mb-6">Join building materials distribution leaders who get our latest articles and industry analysis.</p>
        <div class="max-w-md mx-auto">
          <iframe
            src="https://links.zenprocess.ai/widget/form/3c1xuWglJy5TGfU3dTe4"
            style="width:100%;height:200px;border:none;"
            id="inline-3c1xuWglJy5TGfU3dTe4"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-activation-type="alwaysActivated"
            data-deactivation-type="neverDeactivate"
            data-form-name="Newsletter Signup - zenprocess.ai"
            data-form-id="3c1xuWglJy5TGfU3dTe4"
            title="Newsletter Signup - zenprocess.ai"
            loading="lazy"
          ></iframe>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-4">No spam. Unsubscribe anytime.</p>
        <script is:inline src="https://links.zenprocess.ai/js/form_embed.js"></script>
        <script is:inline>
          (function() {
            var iframe = document.getElementById('inline-3c1xuWglJy5TGfU3dTe4');
            if (!iframe) return;
            var resetTimer = null;
            window.addEventListener('blur', function() {
              if (document.activeElement === iframe) {
                if (resetTimer) clearTimeout(resetTimer);
                resetTimer = setTimeout(function() {
                  iframe.src = iframe.src;
                }, 8000);
              }
            });
          })();
        </script>
      </div>
    </div>
  </section>
</Layout>
