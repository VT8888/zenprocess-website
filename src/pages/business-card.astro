<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vinh Truong — zenprocess.ai</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Be Vietnam Pro', sans-serif; background: #000724; color: #f5f4f0; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 1.5rem; }
      .logo { width: 90px; height: 90px; }
      .content { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; max-width: 28rem; width: 100%; gap: 1.25rem; }
      h1 { font-size: 2.5rem; font-weight: 700; }
      .title { font-size: 1.25rem; font-weight: 500; color: #16A34A; }
      .company { font-size: 1.6rem; color: white; }
      .tagline { font-size: 0.9rem; color: rgba(245,244,240,0.8); font-style: italic; }
      .services { width: 100%; display: flex; flex-direction: column; gap: 0.75rem; margin: 0.5rem 0; }
      .service { display: flex; align-items: center; gap: 0.75rem; text-align: left; font-size: 0.875rem; }
      .service-icon { width: 20px; height: 20px; flex-shrink: 0; }
      .cta { display: block; width: 100%; max-width: 24rem; padding: 1rem 2rem; background: #F59E0B; color: white; border-radius: 0.75rem; font-size: 1.1rem; font-weight: 600; text-decoration: none; text-align: center; transition: opacity 0.2s; }
      .cta:hover { opacity: 0.9; }
      .cta-sub { font-size: 0.8rem; color: #ccc; font-style: italic; margin-top: 0.5rem; }
      .buttons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; width: 100%; margin-top: 0.5rem; }
      .btn { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.25rem; padding: 1rem; border-radius: 0.75rem; text-decoration: none; color: white; font-weight: 500; font-size: 1rem; transition: opacity 0.2s; min-height: 3.5rem; }
      .btn:hover { opacity: 0.9; }
      .btn-blue { background: #0A5FB4; }
      .btn-green { background: #16A34A; }
      .btn-sm { min-height: 3rem; font-size: 0.95rem; }
      .btn-sub { font-size: 0.7rem; opacity: 0.8; }
      .btn-row { display: flex; align-items: center; gap: 0.5rem; }
      .qr { margin-top: 1rem; margin-bottom: 1rem; }
      .qr img { width: 8rem; height: 8rem; border-radius: 0.5rem; }
    </style>
  </head>
  <body>
    <!-- Logo -->
    <div style="width:100%; display:flex; justify-content:center; margin-bottom:2rem;">
      <img src="/logo.png" alt="zenprocess.ai" class="logo" />
    </div>

    <!-- Main Content -->
    <div class="content">
      <h1>Vinh Truong</h1>
      <div class="title">Co-Founder & AI Architect</div>
      <div class="company">zenprocess.ai</div>
      <p class="tagline">Operational Intelligence for Building Materials Distributors</p>

      <!-- Service Highlights -->
      <div class="services">
        <div class="service">
          <svg class="service-icon" style="color:#16A34A" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <span><strong>Real-Time Dashboards</strong> — replacing Excel across your operation</span>
        </div>
        <div class="service">
          <svg class="service-icon" style="color:#0A5FB4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="5" cy="6" r="3"/><path d="M8 6h8"/><circle cx="19" cy="6" r="3"/><circle cx="5" cy="18" r="3"/><path d="M8 18h8"/><circle cx="19" cy="18" r="3"/><path d="M5 9v6"/><path d="M19 9v6"/></svg>
