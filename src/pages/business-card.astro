        <div class="service">
          <svg class="service-icon" style="color:#16A34A" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <span><strong>Proactive Alerts</strong> — catch stockouts before customers call</span>
        </div>
      </div>

      <!-- Primary CTA -->
