<script>
  function formatCurrency(value: number): string {
    return '$' + value.toLocaleString('en-US');
  }

  function calculate(): void {
    const hours = parseInt((document.getElementById('hours') as HTMLInputElement).value);
    const stockouts = parseInt((document.getElementById('stockouts') as HTMLInputElement).value);

    const excelCost = hours * 45 * 52;
    const stockoutCost = stockouts * 2500 * 12;
    const totalCost = excelCost + stockoutCost;

    (document.getElementById('hours-value') as HTMLElement).textContent = String(hours);
    (document.getElementById('stockouts-value') as HTMLElement).textContent = String(stockouts);
    (document.getElementById('excel-cost') as HTMLElement).textContent = formatCurrency(excelCost);
    (document.getElementById('stockout-cost') as HTMLElement).textContent = formatCurrency(stockoutCost);
    (document.getElementById('total-cost') as HTMLElement).textContent = formatCurrency(totalCost);
  }

  document.getElementById('warehouses')?.addEventListener('change', calculate);
  document.getElementById('skus')?.addEventListener('change', calculate);
  document.getElementById('hours')?.addEventListener('input', calculate);
  document.getElementById('stockouts')?.addEventListener('input', calculate);

  calculate();
</script>
