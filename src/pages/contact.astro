---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Book a Discovery Call"
  description="30-minute discovery call about your building materials distribution operation. No pitch deck. Call (832) 974-2818."
>
  <!-- Hero -->
  <section class="py-20 bg-[#000724]">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        Let's talk about your data.
      </h1>
      <p class="text-lg md:text-xl text-[#f5f4f0]/80 max-w-3xl mx-auto leading-relaxed">
        A 30-minute discovery call is the fastest way to find out if we can help. We'll ask about your ERP, your pain points, and your team's daily workflows — and give you an honest answer.
      </p>
    </div>
  </section>

  <!-- Two-Column Layout -->
  <section class="py-20 bg-[#000510]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Left: Book a Call -->
        <div>
          <h2 class="text-2xl font-bold mb-6">Book a Discovery Call</h2>
          <div class="bg-white/5 backdrop-blur-xl rounded-xl p-10 border border-white/10 text-center">
            <p class="text-lg text-[#f5f4f0]/80 mb-8">
              Schedule a 30-minute call to discuss your operation. No pitch deck. No pressure.
            </p>
            <a
              href="https://links.zenprocess.ai/widget/booking/rcoKJifJJA46bRI9fTEr"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-[#16A34A] hover:bg-[#15803D] text-white font-semibold px-10 py-5 rounded-lg text-lg transition-colors shadow-[0_4px_20px_rgba(22,163,74,0.3)]"
            >
              Book a Discovery Call
            </a>
          </div>
        </div>

        <!-- Right: Contact Info + What to Expect -->
        <div class="space-y-12">

          <!-- Direct Contact -->
          <div>
            <h3 class="text-xl font-semibold mb-6">Prefer to reach out directly?</h3>
            <div class="space-y-4">
              <div class="flex items-center gap-4">
                <svg class="w-5 h-5 text-[#16A34A] shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
                <a href="tel:+18329742818" class="text-[#22C55E] hover:text-[#16A34A] text-lg">(832) 974-2818</a>
              </div>
              <div class="flex items-center gap-4">
                <svg class="w-5 h-5 text-[#16A34A] shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                <a href="mailto:info@zenprocess.ai" class="text-[#22C55E] hover:text-[#16A34A] text-lg">info@zenprocess.ai</a>
              </div>
              <div class="flex items-center gap-4">
                <svg class="w-5 h-5 text-[#16A34A] shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                <span class="text-[#f5f4f0]/80 text-lg">Houston, TX</span>
              </div>
              <div class="flex items-center gap-4">
                <svg class="w-5 h-5 text-[#16A34A] shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
                <a href="https://www.linkedin.com/in/vttruong/" target="_blank" rel="noopener noreferrer" class="text-[#22C55E] hover:text-[#16A34A] text-lg">linkedin.com/in/vinhtruong</a>
              </div>
            </div>
          </div>

          <!-- What to Expect -->
          <div>
            <h3 class="text-xl font-semibold mb-6">What to expect</h3>
            <ol class="space-y-5">
              <li class="flex items-start gap-4">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-[#16A34A] text-white text-sm font-bold shrink-0">1</span>
                <span class="text-[#f5f4f0]/80 text-lg"><strong class="text-white">You tell us about your operation</strong> — ERP, warehouses, team size, biggest pain points</span>
              </li>
              <li class="flex items-start gap-4">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-[#16A34A] text-white text-sm font-bold shrink-0">2</span>
                <span class="text-[#f5f4f0]/80 text-lg"><strong class="text-white">We share relevant experience</strong> — what we've built for similar companies, what worked</span>
              </li>
              <li class="flex items-start gap-4">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-[#16A34A] text-white text-sm font-bold shrink-0">3</span>
                <span class="text-[#f5f4f0]/80 text-lg"><strong class="text-white">Honest assessment</strong> — we'll tell you if we can help. If we can't, we'll say so.</span>
              </li>
            </ol>
          </div>

          <!-- Small text -->
          <p class="text-[#6b5e75] text-sm">
            Duration: 30 minutes | Cost: Free | No pitch deck. No pressure.
          </p>

        </div>
      </div>
    </div>
  </section>
</Layout>
