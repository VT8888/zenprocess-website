---
// Hidden page — not in navigation. BNI Power Players chapter contacts.
// No chat widget on this page.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BNI Power Players - Chapter Contacts</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Be Vietnam Pro', sans-serif; background: #ffffff; color: #1a1a1a; min-height: 100vh; }
    </style>
  </head>
  <body>
    <!-- Header -->
    <header style="background:#ED1B24; color:white; padding:1rem;">
      <div style="max-width:36rem; margin:0 auto; text-align:center;">
        <div style="margin-bottom:0.5rem;">
          <span style="font-size:1.875rem; font-weight:700; letter-spacing:-0.025em;">BNI</span>
          <span style="font-size:1rem; font-weight:300; margin-left:0.25rem;">®</span>
        </div>
        <h1 style="font-size:1.25rem; font-weight:700; margin-bottom:0.25rem;">
          Power Players - Chapter Contacts
        </h1>
        <p style="opacity:0.9;">Houston, Texas</p>
        <p style="opacity:0.7; font-size:0.75rem; margin-top:0.25rem;">Updated January 2026</p>
      </div>
    </header>

    <!-- Main Content -->
    <main style="max-width:72rem; margin:0 auto; padding:2.5rem 1rem;">
      <div style="display:grid; grid-template-columns:1fr; gap:2rem;">

        <!-- Instructions -->
        <div style="background:#f9fafb; border-radius:0.75rem; padding:1.5rem;">
          <h2 style="font-size:1.25rem; font-weight:700; color:#111; margin-bottom:1rem;">
            How to Import Contacts
          </h2>
          <ol style="list-style:none; display:flex; flex-direction:column; gap:0.75rem;">
            <li style="display:flex; align-items:flex-start; gap:0.75rem;">
              <span style="flex-shrink:0; width:1.5rem; height:1.5rem; background:#ED1B24; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.875rem; font-weight:700;">1</span>
              <span style="color:#374151; padding-top:0.125rem;">Click the download button below</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:0.75rem;">
              <span style="flex-shrink:0; width:1.5rem; height:1.5rem; background:#ED1B24; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.875rem; font-weight:700;">2</span>
              <span style="color:#374151; padding-top:0.125rem;">Your phone will download the contacts file (.vcf)</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:0.75rem;">
              <span style="flex-shrink:0; width:1.5rem; height:1.5rem; background:#ED1B24; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.875rem; font-weight:700;">3</span>
              <span style="color:#374151; padding-top:0.125rem;">Open the downloaded file</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:0.75rem;">
              <span style="flex-shrink:0; width:1.5rem; height:1.5rem; background:#ED1B24; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.875rem; font-weight:700;">4</span>
              <span style="color:#374151; padding-top:0.125rem;">Tap "Download All Contacts" to download the contacts file.<br/><span style="color:#6b7280; font-size:0.8rem;">(For iPhone users: long-press on "Download All Contacts" to download the .vcf file.)</span></span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:0.75rem;">
              <span style="flex-shrink:0; width:1.5rem; height:1.5rem; background:#ED1B24; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.875rem; font-weight:700;">5</span>
              <span style="color:#374151; padding-top:0.125rem;">Done. All contacts are now saved to your phone.<br/><span style="color:#6b7280; font-size:0.8rem;">(See additional tips for iPhone users below the QR code.)</span></span>
            </li>
          </ol>
        </div>

        <!-- Download Button -->
        <div style="text-align:center;">
          <a
            href="/bni-contacts/BNI_Power_Players_v4_FINAL_20260131.vcf"
            download="BNI_Power_Players_v4_FINAL_20260131.vcf"
            style="display:inline-flex; align-items:center; justify-content:center; gap:0.75rem; background:#ED1B24; color:white; padding:1rem 2rem; border-radius:0.5rem; font-size:1.1rem; font-weight:600; text-decoration:none; min-width:16rem; transition:opacity 0.2s;"
            onmouseover="this.style.opacity='0.9'"
            onmouseout="this.style.opacity='1'"
          >
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
            Download All Contacts
          </a>
        </div>

        <!-- QR Code -->
        <div style="text-align:center; padding:1.5rem; border:2px dashed #e5e7eb; border-radius:0.75rem;">
          <p style="color:#6b7280; font-weight:500; margin-bottom:1rem;">Share with other members:</p>
          <img
            src="/bni-contacts/qr-code.png"
            alt="QR Code - Scan to download BNI Power Players contacts"
            style="width:12rem; height:12rem; margin:0 auto 0.75rem;"
          />
          <p style="color:#9ca3af; font-size:0.875rem;">Scan to download contacts</p>
        </div>

        <!-- iPhone Tips -->
        <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:0.75rem; padding:1.25rem;">
          <div style="display:flex; align-items:flex-start; gap:0.75rem;">
            <svg style="width:20px; height:20px; color:#16a34a; flex-shrink:0; margin-top:0.125rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            <div>
              <p style="color:#166534; font-weight:500; margin-bottom:0.5rem;">Tip for iPhone users</p>
              <p style="color:#15803d; font-size:0.875rem; margin-bottom:0.75rem;">
                After downloading the contact file, do not open it directly from Safari preview. Instead, follow these steps to import all contacts at once:
              </p>
              <ol style="color:#15803d; font-size:0.875rem; list-style:none; display:flex; flex-direction:column; gap:0.375rem; margin-bottom:0.75rem;">
                <li><strong>Step 1.</strong> Open the Files app on your iPhone</li>
                <li><strong>Step 2.</strong> Go to Browse → Downloads<br/><span style="color:#16a34a; font-size:0.75rem;">(If you don't see it, also check iCloud Drive → Downloads or On My iPhone → Downloads)</span></li>
                <li><strong>Step 3.</strong> Find the contact file (.vcf), then long-press the file</li>
                <li><strong>Step 4.</strong> Tap Share</li>
                <li><strong>Step 5.</strong> Select Contacts</li>
                <li><strong>Step 6.</strong> Tap Add All Contacts</li>
              </ol>
              <p style="color:#166534; font-size:0.875rem; font-weight:500;">
                This ensures the full contact list is imported correctly, not just the first contact.
              </p>
            </div>
          </div>
        </div>

        <!-- Member Directory -->
        <div>
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem;">
            <div style="display:flex; align-items:center; gap:0.5rem;">
              <svg style="width:20px; height:20px; color:#ED1B24;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
              <h2 style="font-size:1.25rem; font-weight:700; color:#111;">Member Directory</h2>
            </div>
            <a
              href="/bni-contacts/Power_Players_Members_Jan2026.pdf"
              target="_blank"
              rel="noopener noreferrer"
              style="color:#ED1B24; font-size:0.875rem; font-weight:500; text-decoration:none;"
              onmouseover="this.style.textDecoration='underline'"
              onmouseout="this.style.textDecoration='none'"
            >
              View PDF →
            </a>
          </div>
          <div style="display:flex; flex-direction:column; gap:1rem;">
            <div style="border-radius:0.75rem; overflow:hidden; border:1px solid #e5e7eb; box-shadow:0 1px 2px rgba(0,0,0,0.05);">
              <img src="/bni-contacts/member-directory-page1.jpg" alt="Member Directory Page 1 - Advisors" style="width:100%; height:auto;" />
            </div>
            <div style="border-radius:0.75rem; overflow:hidden; border:1px solid #e5e7eb; box-shadow:0 1px 2px rgba(0,0,0,0.05);">
              <img src="/bni-contacts/member-directory-page2.jpg" alt="Member Directory Page 2 - Providers" style="width:100%; height:auto;" />
            </div>
          </div>
        </div>

      </div>
    </main>

    <!-- Footer -->
    <footer style="background:#f9fafb; border-top:1px solid #e5e7eb; padding:1.5rem 1rem;">
      <div style="max-width:36rem; margin:0 auto; text-align:center;">
        <p style="color:#6b7280; font-size:0.875rem; font-weight:500; margin-bottom:0.5rem;">
          BNI Power Players Chapter - For members only
        </p>
        <p style="color:#9ca3af; font-size:0.75rem;">
          This page is unlisted and for chapter members only
        </p>
      </div>
    </footer>
  </body>
</html>
